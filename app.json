{
  "expo": {
    "name": "CebSpot",
    "slug": "cebspot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F8F7F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cebspot.app"
    },
    "android": {
      "package": "com.cebspot.app",
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CebSpot to access your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CebSpot to access your photos.",
          "cameraPermission": "Allow CebSpot to access your camera."
        }
      ]
    ],
    "scheme": "cebspot",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
